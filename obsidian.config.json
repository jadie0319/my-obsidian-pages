{
  "source": "./vault",
  "output": "./dist",
  "exclude": [
    ".obsidian",
    ".trash"
  ],
  "basePath": "/my-obsidian-pages",
  "template": "default",
  "site": {
    "title": "Jadie Blog",
    "description": "My notes published from Obsidian",
    "author": ""
  },
  "markdown": {
    "preserveWikiLinks": false,
    "convertCallouts": true,
    "syntaxHighlighting": true
  },
  "features": {
    "generateIndex": true,
    "generateSitemap": true,
    "copyAssets": true
  }
}
